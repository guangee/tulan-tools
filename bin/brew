#!/usr/bin/env bash
# tulan-tools 统一入口（命令名: brew）

set -euo pipefail

TULAN_HOME="${TULAN_TOOLS_HOME:-${HOME}/.tulan-tools}"

usage() {
  cat <<EOF
brew — 图蓝工具集（tulan-tools）

用法: brew <命令> [选项]

命令:
  help [主题]         显示帮助
  update              更新工具集仓库
  list                查看可安装的工具与软件包
  versions <名称>     查看可用/已装版本
  install <名称>...   安装（默认最新版）
  use <工具> <版本>   切换二进制版本
  uninstall <名称>    卸载
  docker / conda / vim  环境安装

示例:
  brew list
  brew versions kubectl
  brew install kubectl
  brew install kubectl mc

运行 brew help <主题> 查看详细选项。
EOF
}

main() {
  local cmd="${1:-}"

  case "$cmd" in
    ""|-h|--help|help)
      shift 2>/dev/null || true
      exec "${TULAN_HOME}/scripts/help.sh" "$@"
      ;;
    update|up)
      shift
      exec "${TULAN_HOME}/scripts/update.sh" "$@"
      ;;
    list|ls)
      shift
      exec "${TULAN_HOME}/scripts/list-pkgs.sh" "$@"
      ;;
    versions|version|ver)
      shift
      exec "${TULAN_HOME}/scripts/versions.sh" "$@"
      ;;
    install|i)
      shift
      exec "${TULAN_HOME}/scripts/install.sh" "$@"
      ;;
    download|binaries|dl)
      shift
      echo "[tulan-tools] 提示: download 已改为 install" >&2
      exec "${TULAN_HOME}/scripts/install.sh" "$@"
      ;;
    uninstall|remove)
      shift
      exec "${TULAN_HOME}/scripts/uninstall.sh" "$@"
      ;;
    use|switch)
      shift
      exec "${TULAN_HOME}/scripts/use-binary.sh" "$@"
      ;;
    docker)
      shift
      exec "${TULAN_HOME}/scripts/install-docker.sh" "$@"
      ;;
    conda|miniconda)
      shift
      exec "${TULAN_HOME}/scripts/install-miniconda.sh" "$@"
      ;;
    vim|vimrc)
      shift
      exec "${TULAN_HOME}/scripts/install-vimrc.sh" "$@"
      ;;
    *)
      echo "未知命令: ${cmd}" >&2
      echo "" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
