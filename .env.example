# 复制为 .env 后修改为你的 Docker Hub 镜像
# cp .env.example .env

# Docker Hub 镜像（构建后推送的地址）
TULAN_DOCKER_IMAGE=your-dockerhub-username/tulan-binaries
TULAN_DOCKER_TAG=latest

# 容器名称
TULAN_DOCKER_CONTAINER=tulan-binaries

# Apache 对外端口
TULAN_APACHE_PORT=18080

# docker-compose 工作目录挂载（宿主机路径）
TULAN_DOCKER_WORKDIR=.
